{
  "name": "cv-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cv-api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/cv-api"],
      "cache": true,
      "inputs": ["production"],
      "options": {
        "command": "dotnet publish -c Release -o ../../../dist/apps/cv-api",
        "cwd": "apps/cv-api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "dotnet watch",
        "cwd": "apps/cv-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test",
        "cwd": "apps/cv-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet format --verify-no-changes",
        "cwd": "apps/cv-api"
      }
    },
    "db-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet ef database update",
        "cwd": "apps/cv-api"
      }
    }
  }
}
