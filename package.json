  "scripts": {
    "serve:cv-api": "pkill -9 -f 'nx run cv-api' 2>/dev/null; sleep 1 && npx nx daemon --stop 2>/dev/null; npx nx run cv-api:serve",
    "serve:llm": "pkill -9 -f 'nx run llm-service' 2>/dev/null; sleep 1 && npx nx daemon --stop 2>/dev/null; npx nx run llm-service:serve",
    "serve:app": "pkill -9 -f 'nx run ui-angular' 2>/dev/null; sleep 1 && npx nx daemon --stop 2>/dev/null; npx nx run ui-angular:serve",
    "serve:chat": "pkill -9 -f 'nx run chat-ui' 2>/dev/null; sleep 1 && npx nx daemon --stop 2>/dev/null; npx nx run chat-ui:dev",
    "clean": "pkill -9 -f 'nx run' 2>/dev/null; sleep 1 && npx nx daemon --stop 2>/dev/null && echo 'All nx serve processes cleared'",
    "grpc:generate": ".venv/bin/python3 -m grpc_tools.protoc -I proto --python_out=apps/llm-service/app/grpc --grpc_python_out=apps/llm-service/app/grpc proto/llm_service.proto && sed -i '' 's/^import llm_service_pb2/from . import llm_service_pb2/' apps/llm-service/app/grpc/llm_service_pb2_grpc.py"
  },
  "private": true,
