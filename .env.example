# Copy to `.env` and replace placeholder values. Referenced by `docker-compose.yml`
# (postgres, cv-api, llm-service). Do not commit `.env`.

# --- Postgres ---
POSTGRES_USER=cvmaker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cvmaker

# --- cv-api (compose maps to JwtSettings__Secret) ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- Google Sign-In (OAuth 2.0 Web client ID) ---
# Use the same value in `apps/ui-react` / `apps/ui-angular` `src/environments/environment.ts`
# as `googleClientId`. Docker Compose maps this to cv-api as `Google__ClientId`.

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- llm-service: Gemini when LLM_PROVIDER=google (default in compose) ---
GOOGLE_API_KEY=AIzaSy...

# --- llm-service: provider ---
# google = Gemini | openai / lm_studio / lm-studio = OpenAI-compatible | foundry = Azure AI Foundry (Claude)
LLM_PROVIDER=google

# Model / deployment name: Gemini model when google; Anthropic deployment when foundry; overrides OPENAI_MODEL when openai.
# LLM_MODEL=gemini-1.5-flash

# Optional sampling temperature 0–2 (default 0.4).
# LLM_TEMPERATURE=0.4

# --- LLM_PROVIDER=openai (LM Studio, local OpenAI-compatible, etc.) ---
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# From a container to LM Studio on the host: http://host.docker.internal:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=local-model

# --- LLM_PROVIDER=foundry (variable names match apps/llm-service/app/settings.py) ---
# Key from Azure portal (Keys and Endpoint). Required when LLM_PROVIDER=foundry.
# FOUNDRY_API_KEY=

# Full base URL to the Anthropic-compatible endpoint, no trailing slash (e.g. .../anthropic).
# If unset, the client uses FOUNDRY_DEPLOYMENT_NAME as the Azure resource name instead.
# FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com/anthropic

# Resource / deployment: used as Azure `resource=` when FOUNDRY_BASE_URL is empty; also model name
# when LLM_MODEL is unset. Prefer setting LLM_MODEL for the deployment name when both are needed.
# FOUNDRY_DEPLOYMENT_NAME=your-resource

# LLM_MODEL=claude-haiku-4-5

# Optional max tokens for Foundry (default 8192).
# ANTHROPIC_FOUNDRY_MAX_TOKENS=8192

# --- LLM Evals (Azure AI Foundry portal logging, optional) ---
# When set, eval results are logged to the Azure AI Foundry project in the portal.
# If unset, evals still run and write results to evals/results/ locally.
# Project endpoint from: az cognitiveservices account project show ... -> properties.endpoints["AI Foundry API"]
# AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
