# Copy to terraform.tfvars (git-ignored) and fill in real values.

gcp_project_id = "your-gcp-project-id"
project_name   = "ai-cv-maker"
region         = "europe-central2"

postgres_admin_login    = "cvmaker"
postgres_admin_password = "change-me-strong-password"

jwt_secret             = "change-me-at-least-32-chars-long-secret"
google_web_client_id   = "your-client-id.apps.googleusercontent.com"
# google_extension_client_id = "your-extension-client-id.apps.googleusercontent.com"
# google_client_secret       = "your-client-secret"

# --- LLM settings — google (Gemini) is the default ---
llm_provider = "google"
# llm_model       = "gemini-1.5-flash"   # optional override
# llm_temperature = "0.4"                # optional, 0–2

# --- LLM_PROVIDER=google ---
google_api_key = "AIzaSy..."

# --- LLM_PROVIDER=openai (LM Studio, local OpenAI-compatible, etc.) ---
# openai_base_url = "http://127.0.0.1:1234/v1"
# openai_api_key  = "lm-studio"
# openai_model    = "local-model"

# --- LLM_PROVIDER=foundry (Azure AI Foundry / Claude) ---
# foundry_api_key             = ""
# foundry_base_url            = "https://your-resource.services.ai.azure.com/anthropic"
# foundry_deployment_name     = "your-resource"
# anthropic_foundry_max_tokens = "8192"
# llm_model                   = "claude-haiku-4-5"

# --- Grafana ---
grafana_admin_user     = "admin"
grafana_admin_password = "change-me-grafana-password"

# --- Admin panel ---
admin_jwt_secret  = "change-me-admin-jwt-secret"
# admin_seed_email = "admin@example.com"

# Password for the admin_readonly role on the main DB (ADR-0004). Must match the
# password you pass when running apps/admin-api/migrations/create-readonly-role.sql.
admin_readonly_db_password = "change-me-readonly-password"
