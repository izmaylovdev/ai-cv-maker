{
  "id": null,
  "uid": "cv-maker-tracing",
  "title": "CV Maker — Request Tracing",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "sum(increase(http_requests_received_total{job=\"cv-api\"}[1h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (1h)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "sum(increase(http_requests_received_total{job=\"cv-api\",statusCode=~\"5..\"}[1h])) / sum(increase(http_requests_received_total{job=\"cv-api\"}[1h])) * 100",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency (5m)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cv-api\"}[$__rate_interval]))) * 1000",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "sum by (endpoint) (rate(http_requests_received_total{job=\"cv-api\"}[$__rate_interval]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Avg Latency by Endpoint (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "sum by (endpoint) (rate(http_request_duration_seconds_sum{job=\"cv-api\"}[$__rate_interval])) / sum by (endpoint) (rate(http_request_duration_seconds_count{job=\"cv-api\"}[$__rate_interval])) * 1000",
          "legendFormat": "{{endpoint}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cv-api\"}[$__rate_interval]))) * 1000",
          "legendFormat": "P95 overall"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "gRPC Call Duration by Method (ms)",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "sum by (method) (rate(grpc_server_handled_seconds_sum{job=\"llm-service\"}[$__rate_interval])) / sum by (method) (rate(grpc_server_handled_seconds_count{job=\"llm-service\"}[$__rate_interval])) * 1000",
          "legendFormat": "{{method}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP P95 Latency by Endpoint (ms)",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cv-maker" },
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{job=\"cv-api\"}[$__rate_interval]))) * 1000",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Slowest Endpoints (24h avg)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "pg-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "pg-cv-maker" },
          "format": "table",
          "rawSql": "SELECT \"Operation\", COUNT(*) AS requests, ROUND(AVG(\"DurationMs\")::numeric, 0)::int AS avg_ms, ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY \"DurationMs\")::numeric, 0)::int AS p95_ms, SUM(CASE WHEN \"IsError\" THEN 1 ELSE 0 END) AS errors FROM \"RequestSpans\" WHERE \"SpanKind\" = 'http' AND \"StartedAt\" > NOW() - INTERVAL '24 hours' GROUP BY \"Operation\" ORDER BY avg_ms DESC LIMIT 20"
        }
      ],
      "options": { "sortBy": [{ "displayName": "avg_ms", "desc": true }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg_ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "Avg (ms)" }]
          },
          {
            "matcher": { "id": "byName", "options": "p95_ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "P95 (ms)" }]
          },
          {
            "matcher": { "id": "byName", "options": "requests" },
            "properties": [{ "id": "displayName", "value": "Requests" }]
          },
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Recent End-to-End Traces",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "pg-cv-maker" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "pg-cv-maker" },
          "format": "table",
          "rawSql": "SELECT TO_CHAR(h.\"StartedAt\" AT TIME ZONE 'UTC', 'HH24:MI:SS') AS time, h.\"Operation\" AS endpoint, h.\"StatusCode\" AS status_code, h.\"DurationMs\" AS total_ms, g.\"Operation\" AS grpc_method, g.\"DurationMs\" AS grpc_ms, h.\"IsError\" AS error FROM \"RequestSpans\" h LEFT JOIN \"RequestSpans\" g ON g.\"TraceId\" = h.\"TraceId\" AND g.\"SpanKind\" = 'grpc' WHERE h.\"SpanKind\" = 'http' AND h.\"StartedAt\" > NOW() - INTERVAL '1 hour' ORDER BY h.\"StartedAt\" DESC LIMIT 50"
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total_ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "Total (ms)" }]
          },
          {
            "matcher": { "id": "byName", "options": "grpc_ms" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "gRPC (ms)" }]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    }
  ]
}
